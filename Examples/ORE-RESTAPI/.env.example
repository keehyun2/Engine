# ORE Configuration
# Path to ORE executable (ore.exe on Windows, ore on Linux/Mac)
# If empty, will auto-search in known build locations
ORE_PATH=

# ORE execution timeout in seconds
ORE_TIMEOUT_SECONDS=600

# Database
# DATABASE_URL=sqlite:///./ore_api.db

# Redis (only needed if DEV_MODE=false)
# REDIS_URL=redis://localhost:6379/0

# Development mode (set to false to use Redis queue)
# DEV_MODE=true
