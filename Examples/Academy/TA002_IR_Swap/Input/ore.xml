<?xml version="1.0"?>
<!-- ======================================== -->
<!-- ORE 금리 스왑(IR Swap) 가격 예제 설정 파일 -->
<!-- Academy/TA002_IR_Swap                  -->
<!-- ======================================== -->
<!--
  [IR Swap(Interest Rate Swap)이란?]
  - 두 당사자 간의 고정 금리와 변동 금리 현금흐름 교환 계약
  - 고정 금리 지급자(Fixed Rate Payer)와 변동 금리 수신자(Floating Rate Receiver)로 구성
  - 금리 리스크 헷지, 투기, 차입 비용 최적화 등에 활용

  [이 예제의 특징]
  - EUR 기반 20년 만기 IR Swap
  - 고정 금리: 4% (수신, Fixed Receiver)
  - 변동 금리: EURIBOR 6M (지급, Floating Payer)
  - 명목 금액: EUR 10,000,000

  [파일 구조]
  1. Setup: 기본 설정 및 입력 파일 경로
  2. Markets: 시장 데이터 컨피규레이션
  3. Analytics: 실행할 분석(NPV, Cashflow, Curves)
-->

<ORE>
  <Setup>
    <!-- ========== 1. 기본 설정 ========== -->

    <!-- asofDate: 가격 평가 기준일 -->
    <Parameter name="asofDate">2016-02-05</Parameter>

    <!-- 입력/출력 폴더 경로 -->
    <Parameter name="inputPath">Input</Parameter>
    <Parameter name="outputPath">Output</Parameter>

    <!-- ========== 2. 필수 입력 파일 경로 ========== -->

    <!-- marketDataFile: 시장 데이터 (금리, 통화 등) -->
    <Parameter name="marketDataFile">market.txt</Parameter>

    <!-- fixingDataFile: 과거 금리 수정(Fixing) 데이터 -->
    <Parameter name="fixingDataFile">fixings.txt</Parameter>

    <!-- curveConfigFile: 수익률 곡선 구성 정의 -->
    <Parameter name="curveConfigFile">curveconfig.xml</Parameter>

    <!-- conventionsFile: 시장 관습(캘린더, 롤오버 등) -->
    <Parameter name="conventionsFile">conventions.xml</Parameter>

    <!-- marketConfigFile: 오늘의 시장 구성 (할인/포워딩 곡선 매핑) -->
    <Parameter name="marketConfigFile">todaysmarket.xml</Parameter>

    <!-- pricingEnginesFile: 가격 결정 엔진 설정 -->
    <Parameter name="pricingEnginesFile">pricingengine.xml</Parameter>

    <!-- portfolioFile: 분석할 파생상품 포트폴리오 -->
    <Parameter name="portfolioFile">irswap.xml</Parameter>

    <!-- ========== 3. 기타 파라미터 ========== -->

    <!-- 로그 파일 설정 -->
    <Parameter name="logFile">log.txt</Parameter>
    <Parameter name="logMask">255</Parameter>

    <!-- 금일 Fixing 자동 계산 여부 -->
    <Parameter name="implyTodaysFixings">N</Parameter>
  </Setup>

  <Markets>
    <!-- ========== 시장 컨피규레이션 ========== -->
    <!--
      [여러 market context]
      - lgmcalibration: LGM 모델 보정용 시장
      - fxcalibration: FX 옵션 보정용 시장
      - eqcalibration: Equity 옵션 보정용 시장
      - pricing: 일반 가격 결정용 시장 (가장 중요)
      - simulation: 시뮬레이션용 시장

      이 예제는 "default" 컨피규레이션을 사용합니다.
    -->
    <Parameter name="lgmcalibration">default</Parameter>
    <Parameter name="fxcalibration">default</Parameter>
    <Parameter name="eqcalibration">default</Parameter>
    <Parameter name="pricing">default</Parameter>
    <Parameter name="simulation">default</Parameter>
  </Markets>

  <Analytics>
    <!-- ========== 분석 항목 설정 ========== -->

    <!-- NPV (Net Present Value) 분석 -->
    <Analytic type="npv">
      <Parameter name="active">Y</Parameter>
      <Parameter name="baseCurrency">EUR</Parameter>
      <Parameter name="outputFileName">npv.csv</Parameter>
    </Analytic>

    <!-- 캐시플로우 분석 -->
    <Analytic type="cashflow">
      <Parameter name="active">Y</Parameter>
      <Parameter name="outputFileName">flows.csv</Parameter>
    </Analytic>

    <!-- 수익률 곡선 분석 -->
    <Analytic type="curves">
      <Parameter name="active">Y</Parameter>
      <Parameter name="configuration">default</Parameter>
      <!-- grid: 240개월(20년)을 1개월 단위로 출력 -->
      <Parameter name="grid">240,1M</Parameter>
      <Parameter name="outputFileName">curves.csv</Parameter>
    </Analytic>
  </Analytics>

</ORE>
